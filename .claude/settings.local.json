{
  "permissions": {
    "allow": [
      "Bash(netstat:*)",
      "Bash(findstr:*)",
      "Bash(taskkill:*)",
      "Bash(powershell -Command \"Stop-Process -Id 6136 -Force\")",
      "Bash(if exist .angular rd /s /q .angular)",
      "Bash(npm start)",
      "Bash(dir:*)",
      "Bash(timeout /t 20)",
      "Bash(ping:*)",
      "Bash(npm run build:*)",
      "Bash(ng build:*)",
      "Bash(firebase deploy:*)",
      "Bash(firebase hosting:sites:get:*)",
      "Bash(nslookup:*)",
      "Bash(ls:*)",
      "Bash(node -e:*)",
      "Bash(xargs grep:*)",
      "Bash(grep -r \"createOrder\\\\|addToCart\" '/d/New folder/roofrix-site/src' --include=*.ts)",
      "Bash(npx ng:*)",
      "Read(//d//**)",
      "Bash(rm -rf public/*.js public/*.css public/*.html)",
      "Bash(cp -r dist/roofrix-site/browser/* public/)",
      "Bash(sed 's/.*@media[^0-9]*//')",
      "Bash(sed 's/[^0-9].*$//')"
    ]
  }
}
